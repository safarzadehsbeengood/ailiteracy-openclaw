{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "workspace": "./workspace"
    },
    "list": [
      {
        "id": "my_agent",
        "default": true,
        "name": "Carbon-Based Caleb",
        "workspace": "./workspace",
        "identity": {
          "name": "Carbon-Based Caleb"
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "my_agent",
      "match": {
        "channel": "discord"
      }
    }
  ],
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_TOKEN}",
      "dmPolicy": "disabled",
      "guilds": {
        "${DISCORD_GUILD_ID}": {
          "requireMention": false,
          "channels": {
            "${INFO_ANNOUNCEMENTS_CHANNEL_ID}": {
              "allow": true,
              "requireMention": false
            },
            "${ACTIVE_TOPICS_CATEGORY_ID}": {
              "allow": true,
              "requireMention": false
            },
            "${ARCHIVED_CATEGORY_ID}": {
              "allow": true,
              "requireMention": false
            }
          }
        }
      },
      "threadBindings": {
        "enabled": true
      }
    }
  }
}
